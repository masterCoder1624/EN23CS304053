# ============================================================================
# InsightHub Configuration (.env file)
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control
# ============================================================================

# ── MongoDB Configuration ─────────────────────────────────────────────────
# Local MongoDB (development)
MONGO_URI=mongodb://localhost:27017

# MongoDB Atlas (production/cloud)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database and collection names
DATABASE_NAME=insighthub
REVIEWS_COLLECTION=reviews

# ── Application Settings ──────────────────────────────────────────────────
# Debug mode (set to 'true' for development, 'false' for production)
DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=10

# ── CORS Configuration ────────────────────────────────────────────────────
# Allowed origins for cross-origin requests (comma-separated)
# For development: "*" or "http://localhost:3000,http://10.0.2.2:*"
# For production: Use specific domains only
CORS_ORIGINS=*

# ── API Server Settings ───────────────────────────────────────────────────
# Host and port for the FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# ── Flutter/Client Configuration ──────────────────────────────────────────
# Note: These are example values. Adjust based on your setup.
# Android Emulator: 10.0.2.2:8000 (default, localhost from emulator perspective)
# Physical Device: <YOUR_MACHINE_IP>:8000
# iOS Simulator: localhost:8000 or 127.0.0.1:8000
# Web: <YOUR_DOMAIN>:8000

