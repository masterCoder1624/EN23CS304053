# InsightHub Local Development Configuration
# ============================================================================

# ── MongoDB Configuration ─────────────────────────────────────────────────
# Using local MongoDB instance for development
MONGO_URI=mongodb://localhost:27017

# Database names
DATABASE_NAME=insighthub
REVIEWS_COLLECTION=reviews

# ── Application Settings ──────────────────────────────────────────────────
# Enable debug mode for development
DEBUG=true

# Logging level
LOG_LEVEL=INFO

# Upload file size limit
MAX_UPLOAD_SIZE_MB=10

# ── CORS Configuration ────────────────────────────────────────────────────
# Allow requests from all origins (development only)
# For production, specify: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# ── API Server Settings ───────────────────────────────────────────────────
# Listen on all interfaces (0.0.0.0) in containers, localhost for local dev
API_HOST=0.0.0.0
API_PORT=8000

